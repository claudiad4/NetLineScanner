@page "/devices"
@using NetLine.Web.Services
@using NetLine.Domain.Entities;
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject IConfiguration Config
@implements IAsyncDisposable

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Monitor Urządzeń</PageTitle>

<style>
    .text-purple {
        color: #6f42c1 !important;
    }

    .bg-soft-success {
        background-color: #d1e7dd !important;
        color: #0f5132 !important;
        border: 1px solid #badbcc !important;
    }

    .bg-soft-danger {
        background-color: #f8d7da !important;
        color: #842029 !important;
        border: 1px solid #f5c2c7 !important;
    }

    .detail-row {
        background-color: #f8faff;
        animation: fadeIn 0.3s ease-out;
    }

    .details-container {
        padding: 20px;
        border-left: 5px solid #6f42c1;
        margin: 10px 0 10px 40px;
        background: white;
        border-radius: 0 8px 8px 0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .table-hover tbody tr:not(.detail-row):hover {
        background-color: rgba(111, 66, 193, 0.05);
        cursor: pointer;
    }

    .badge-tech {
        font-size: 0.7rem;
        padding: 4px 8px;
        font-weight: bold;
        min-width: 55px;
        text-align: center;
        border-radius: 4px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2 text-purple"></i> Monitor Sieciowy</h1>
    <span class="badge bg-success border shadow-sm p-2">Status: Połączono Live</span>
</div>

@if (devices == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Inicjalizacja monitoringu...</p>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table align-middle bg-white table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width: 40px;"></th>
                    <th style="width: 130px;">Status</th>
                    <th style="width: 140px;">Protokół</th>
                    <th>Urządzenie</th>
                    <th>Adres IP</th>
                    <th>Ostatni skan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in devices)
                {
                    <tr @onclick="() => ToggleDetails(device.Id)">
                        <td class="text-center">
                            <i class="bi @(expandedDeviceId == device.Id ? "bi-chevron-down text-purple" : "bi-chevron-right text-muted")"></i>
                        </td>
                        <td>
                            @{
                                var statusClass = device.Status == "Offline" ? "bg-danger" : "bg-success";
                                var iconClass = device.Status == "Offline" ? "bi-x-circle" : "bi-check-circle";
                            }
                            <span class="badge rounded-pill @statusClass w-100 shadow-sm">
                                <i class="bi @iconClass"></i> @(device.Status == "Offline" ? "Offline" : "Online")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <span class="badge @(device.PingResponseTimeMs.HasValue ? "bg-soft-success" : "bg-soft-danger") badge-tech">ICMP</span>
                                <span class="badge @(!string.IsNullOrEmpty(device.SysUpTime) && device.SysUpTime != "Brak danych" ? "bg-soft-success" : "bg-soft-danger") badge-tech">SNMP</span>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                @* ZMIANA: Szare kółko (#e9ecef), czarna ikona *@
                                <div class="me-3 d-flex align-items-center justify-content-center rounded-circle"
                                     style="width: 40px; height: 40px; background-color: #e9ecef; color: black;">
                                    @* Wyświetlamy ikonę dynamicznie *@
                                    <i class="bi @GetIconForType(device.DeviceType)" style="font-size: 1.2rem;"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">@device.UserDefinedName</div>
                                    <small class="text-muted d-block" style="margin-top: -4px;">
                                        <i class="bi bi-tag"></i> @device.DeviceType
                                    </small>
                                </div>
                            </div>
                        </td>
                        <td><code class="text-purple fw-bold">@device.IpAddress</code></td>
                        <td><small class="text-muted">@device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</small></td>
                    </tr>

                    @if (expandedDeviceId == device.Id)
                    {
                        <tr class="detail-row">
                            <td colspan="6">
                                <div class="details-container">
                                    <div class="row">
                                        <div class="col-md-4 border-end">
                                            <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-info-square"></i> Dane Systemowe</h6>
                                            <p class="mb-1 small"><strong>Nazwa SNMP:</strong> @(device.SysName ?? "Brak danych")</p>
                                            <p class="mb-1 small"><strong>Lokalizacja:</strong> @(device.SysLocation ?? "Nieznana")</p>
                                            <p class="mb-1 small"><strong>Kontakt:</strong> @(device.SysContact ?? "Brak")</p>
                                        </div>
                                        <div class="col-md-4 border-end">
                                            <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-activity"></i> Status Pracy</h6>
                                            <p class="mb-1 small"><strong>UpTime:</strong> @(device.SysUpTime ?? "Niedostępny")</p>
                                            <p class="mb-1 small"><strong>Interfejsy:</strong> @(device.SysInterfacesCount?.ToString() ?? "---")</p>
                                            <p class="mb-1 small"><strong>Ostatni Ping:</strong> @(device.PingResponseTimeMs?.ToString() ?? "---") ms</p>
                                        </div>
                                        <div class="col-md-4">
                                            <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-file-earmark-text"></i> Komunikat</h6>
                                            <small class="text-muted" style="font-size: 0.75rem;">
                                                @if (string.IsNullOrEmpty(device.SysUpTime) || device.SysUpTime == "Brak danych")
                                                {
                                                    <span>@(device.PingResponseTimeMs.HasValue ? "Urządzenie aktywne (Ping OK). Brak obsługi SNMP." : "Urządzenie nieosiągalne.")</span>
                                                }
                                                else
                                                {
                                                    @(device.SysDescr ?? "Pobrano opis SNMP.")
                                                }
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<DeviceInfo>? devices;
    private HubConnection? hubConnection;
    private int? expandedDeviceId;

    private void ToggleDetails(int id) => expandedDeviceId = (expandedDeviceId == id) ? null : id;

    // Metoda elastyczna: sprawdza czy typ ma przypisaną ikonę.
    // Jeśli nie, zakłada że 'type' to nazwa ikony (np. "laptop", "phone").
    private string GetIconForType(string? type)
    {
        if (string.IsNullOrEmpty(type)) return "bi-three-dots";

        return type switch
        {
            "Komputer" => "bi-pc-display",
            "Serwer" => "bi-hdd-network",
            "Switch" => "bi-router",
            "Drukarka" => "bi-printer",
            "Inne" => "bi-three-dots",
            // Jeśli typ nie pasuje do powyższych, użyj typu jako nazwy ikony (np. bi-laptop)
            _ => $"bi-{type.ToLower()}"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        var apiBaseUrl = Config["services:apiservice:http:0"] ?? Config["services:apiservice:https:0"];
        if (!string.IsNullOrEmpty(apiBaseUrl))
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiBaseUrl}/devicehub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On("DeviceStatusUpdated", async () =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });
            await hubConnection.StartAsync();
        }
    }

    private async Task LoadData()
    {
        try { devices = await ApiClient.GetDevicesAsync(); }
        catch (Exception ex) { Console.WriteLine($"Błąd: {ex.Message}"); }
    }

    public async ValueTask DisposeAsync() { if (hubConnection is not null) await hubConnection.DisposeAsync(); }
}