@page "/devices"
@using NetLine.Web.Services
@using NetLine.ApiService.Models
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>Monitoring Urządzeń</PageTitle>

<style>
    .bg-soft-success {
        background-color: #d1e7dd !important;
        color: #0f5132 !important;
        border: 1px solid #badbcc !important;
    }

    .bg-soft-danger {
        background-color: #f8d7da !important;
        color: #842029 !important;
        border: 1px solid #f5c2c7 !important;
    }

    .detail-row {
        background-color: #f8faff;
        animation: fadeIn 0.3s ease-out;
    }

    .details-container {
        padding: 20px;
        border-left: 5px solid #0d6efd;
        margin: 10px 0 10px 40px;
        background: white;
        border-radius: 0 8px 8px 0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .table-hover tbody tr:not(.detail-row):hover {
        background-color: rgba(13, 110, 253, 0.05);
        cursor: pointer;
    }

    .badge-tech {
        font-size: 0.7rem;
        padding: 4px 8px;
        font-weight: bold;
        min-width: 55px;
        text-align: center;
        border-radius: 4px;
    }
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(-5px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2"></i> Monitor Sieciowy</h1>
    <div class="text-end">
        <span class="badge bg-success border shadow-sm p-2">Status: Połączono Live</span>
    </div>
</div>

@if (devices == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Pobieranie danych...</p>
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table align-middle bg-white table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width: 40px;"></th>
                    <th style="width: 130px;">Status</th>
                    <th style="width: 140px;">Protokół</th>
                    <th>Urządzenie</th>
                    <th>Adres IP</th>
                    <th>Odpowiedź</th>
                    <th>Ostatni skan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in devices)
                {
                    <tr @onclick="() => ToggleDetails(device.Id)">
                        <td class="text-center">
                            <i class="bi @(expandedDeviceId == device.Id ? "bi-chevron-down text-primary" : "bi-chevron-right text-muted")"></i>
                        </td>
                        <td>
                            @{
                                // Jeśli urządzenie odpowiada na ping, zawsze pokazujemy zielony status Online
                                var statusClass = device.Status == "Offline" ? "bg-danger" : "bg-success";
                                var iconClass = device.Status == "Offline" ? "bi-x-circle" : "bi-check-circle";
                                var statusText = device.Status == "Offline" ? "Offline" : "Online";
                            }
                            <span class="badge rounded-pill @statusClass w-100 shadow-sm">
                                <i class="bi @iconClass"></i> @statusText
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                @* ICMP Label *@
                                @if (device.PingResponseTimeMs.HasValue)
                                {
                                    <span class="badge bg-soft-success badge-tech" title="Urządzenie odpowiada na Ping">ICMP</span>
                                }
                                else
                                {

                                    <span class="badge bg-soft-danger badge-tech" title="Brak odpowiedzi Ping">ICMP</span>
                                }

                                @* SNMP Label *@
                                @if (!string.IsNullOrEmpty(device.SysUpTime) && device.SysUpTime != "Brak danych")
                                {
                                    <span class="badge bg-soft-success badge-tech" title="Protokół SNMP aktywny">SNMP</span>
                                }
                                else
                                {

                                    <span class="badge bg-soft-danger badge-tech" title="Brak danych protokołu SNMP">SNMP</span>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold">@device.UserDefinedName</div>
                            <small class="text-muted">
                                @(string.IsNullOrEmpty(device.SysName) ? "Urządzenie bez agenta SNMP" : device.SysName)
                            </small>
                        </td>
                        <td><code class="text-primary fw-bold">@device.IpAddress</code></td>
                        <td>@(device.PingResponseTimeMs.HasValue ? $"{device.PingResponseTimeMs} ms" : "---")</td>
                        <td><small>@device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</small></td>
                    </tr>

                    @if (expandedDeviceId == device.Id)
                    {
                        <tr class="detail-row">
                            <td colspan="7">
                                <div class="details-container">
                                    <div class="row">
                                        <div class="col-md-4 border-end">
                                            <h6 class="fw-bold text-primary border-bottom pb-1">
                                                <i class="bi bi-info-square"></i> Dane Systemowe
                                            </h6>
                                            <p class="mb-1"><strong>Nazwa SNMP:</strong> @(device.SysName ?? "Brak danych")</p>
                                            <p class="mb-1"><strong>Lokalizacja:</strong> @(device.SysLocation ?? "Nieznana")</p>
                                            <p class="mb-1"><strong>Kontakt:</strong> @(device.SysContact ?? "Brak")</p>
                                        </div>
                                        <div class="col-md-4 border-end">
                                            <h6 class="fw-bold text-primary border-bottom pb-1"><i class="bi bi-activity"></i> Status Pracy</h6>
                                            <p class="mb-1">
                                                <strong>UpTime:</strong>
                                                <span class="@(string.IsNullOrEmpty(device.SysUpTime) || device.SysUpTime == "Brak danych" ? "text-muted" : "text-success")">
                                                    @(device.SysUpTime ?? "Niedostępny")
                                                </span>
                                            </p>
                                            <p class="mb-1"><strong>Interfejsy:</strong> @(device.SysInterfacesCount?.ToString() ?? "---")</p>
                                            <p class="mb-1"><strong>Ostatni Ping:</strong> @(device.PingResponseTimeMs?.ToString() ?? "---") ms</p>
                                        </div>
                                        <div class="col-md-4">
                                            <h6 class="fw-bold text-primary border-bottom pb-1"><i class="bi bi-file-earmark-text"></i> Komunikat</h6>
                                            <small class="text-muted">
                                                @if (string.IsNullOrEmpty(device.SysUpTime) || device.SysUpTime == "Brak danych")
                                                {
                                                    if (device.PingResponseTimeMs.HasValue)
                                                    {
                                                        <span>Urządzenie aktywne (Ping OK). Brak obsługi SNMP lub usługa jest wyłączona (standardowe dla telefonów/PC).</span>
                                                    }
                                                    else
                                                    {
                                                        <span>Urządzenie nieosiągalne. Sprawdź zasilanie i połączenie sieciowe.</span>
                                                    }
                                                }
                                                else
                                                {
                                                    @(device.SysDescr ?? "Pobrano pełny opis systemowy SNMP.")
                                                }
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<DeviceInfo>? devices;
    private HubConnection? hubConnection;
    private int? expandedDeviceId;

    private void ToggleDetails(int id) => expandedDeviceId = (expandedDeviceId == id) ? null : id;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        // Service Discovery pobiera adres API dynamicznie
        var apiBaseUrl = Config["services:apiservice:http:0"] ?? Config["services:apiservice:https:0"];

        if (!string.IsNullOrEmpty(apiBaseUrl))
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiBaseUrl}/devicehub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On("DeviceStatusUpdated", async () =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
        }
    }

    private async Task LoadData()
    {
        try { devices = await ApiClient.GetDevicesAsync(); }
        catch (Exception ex) { Console.WriteLine($"Błąd pobierania danych: {ex.Message}"); }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) await hubConnection.DisposeAsync();
    }
}