@page "/add-device"
@using NetLine.Web.Services
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject NavigationManager Nav

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Dodaj Urządzenie</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh; padding: 20px;">
    <div class="card p-4 shadow-sm" style="width: 100%; max-width: 500px;">
        <h3 class="mb-4 text-center">Dodaj nowe urządzenie</h3>

        <div class="mb-3">
            <label class="form-label d-block fw-bold">Adres IP</label>
            <div class="d-flex align-items-center justify-content-between">
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip1" style="width: 70px;" />
                <span class="fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip2" style="width: 70px;" />
                <span class="fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip3" style="width: 70px;" />
                <span class="fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip4" style="width: 70px;" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Nazwa własna</label>
            <input @bind="label" class="form-control" placeholder="np. Drukarka w salonie" />
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Rodzaj urządzenia</label>
            <select class="form-select" @bind="deviceType">
                <option value="Komputer">Komputer</option>
                <option value="Serwer">Serwer</option>
                <option value="Switch">Switch</option>
                <option value="Drukarka">Drukarka</option>
                <option value="Laptop">Laptop</option>
                <option value="Telefon">Telefon</option>
                <option value="Tablet">Tablet</option>
                <option value="Inne">Inne</option>
            </select>
        </div>

        <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="Submit" disabled="@isLoading" style="background-color: #6f42c1; border-color: #6f42c1;">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
                <span> Dodawanie...</span>
            }
            else
            {
                <span>Dodaj urządzenie</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    private string ip1 = ""; private string ip2 = ""; private string ip3 = ""; private string ip4 = "";
    private string label = "";
    private string deviceType = "Komputer";
    private bool isLoading = false;
    private string? errorMessage;

    private async Task Submit()
    {
        isLoading = true;
        errorMessage = null;
        string fullIp = $"{ip1}.{ip2}.{ip3}.{ip4}";

        try
        {
            // Wysyłamy po prostu wybrany typ z listy.
            // Dzięki logice w Devices.razor, ikona dobierze się sama.
            var success = await ApiClient.AddDeviceAsync(fullIp, label, deviceType);

            if (success)
            {
                Nav.NavigateTo("/devices");
            }
            else
            {
                errorMessage = "Błąd zapisu na serwerze.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Błąd połączenia: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}