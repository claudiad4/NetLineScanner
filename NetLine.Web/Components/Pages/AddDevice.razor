@page "/add-device"
@using NetLine.Web.Services
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>Dodaj Urządzenie</PageTitle>

@* Kontener centrujący na środku ekranu *@
<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4 shadow-sm" style="width: 100%; max-width: 450px;">
        <h3 class="mb-4 text-center">Dodaj nowe urządzenie</h3>

        <div class="mb-3">
            <label class="form-label d-block">Adres IP</label>
            @* Podział na 4 małe pola z kropkami *@
            <div class="d-flex align-items-center">
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip1" style="width: 60px;" />
                <span class="mx-1 fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip2" style="width: 60px;" />
                <span class="mx-1 fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip3" style="width: 60px;" />
                <span class="mx-1 fw-bold">.</span>
                <input type="text" maxlength="3" class="form-control text-center px-1" @bind="ip4" style="width: 60px;" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Nazwa własna</label>
            <input @bind="label" class="form-control" placeholder="np. Drukarka w salonie" />
        </div>

        <div class="mb-4">
            <label class="form-label">Rodzaj urządzenia</label>
            <select class="form-select" @bind="deviceType">
                <option value="Komputer">Komputer</option>
                <option value="Serwer">Serwer</option>
                <option value="Switch">Switch</option>
                <option value="Drukarka">Drukarka</option>
                <option value="Other">Inne</option>
            </select>
        </div>

        <button class="btn btn-primary w-100" @onclick="Submit" disabled="@isLoading">
            @if (isLoading) {
                <span class="spinner-border spinner-border-sm"></span> <span> Dodawanie urządzenia...</span>
            } else {
                <span>Dodaj urządzenie</span>
            }
        </button>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
        }
    </div>
</div>

@code {
    // Rozbicie IP na 4 części dla formularza
    private string ip1 = "";
    private string ip2 = "";
    private string ip3 = "";
    private string ip4 = "";
    
    private string label = "";
    private string deviceType = "Komputer"; // Domyślna wartość
    private bool isLoading = false;
    private string? errorMessage;

    private async Task Submit()
    {
        isLoading = true;
        errorMessage = null;
        
        // Złożenie IP z powrotem w jeden ciąg
        string fullIp = $"{ip1}.{ip2}.{ip3}.{ip4}";
        
        try 
        {
            // Przekazujemy wybraną wartość deviceType do API
            var success = await ApiClient.AddDeviceAsync(fullIp, label, deviceType);
            
            if (success) 
            {
                Nav.NavigateTo("/devices");
            } 
            else 
            {
                errorMessage = "Serwer nie mógł dodać urządzenia. Sprawdź czy IP jest poprawne.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Błąd połączenia: " + ex.Message;
        }
        finally 
        {
            isLoading = false;
        }
    }
}