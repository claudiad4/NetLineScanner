@page "/offices/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>@(office?.Name ?? "Biuro")</PageTitle>

@if (accessDenied)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-shield-lock"></i> Nie masz uprawnień do tego biura.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            @if (isAdmin)
            {
                <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/offices")'>
                    <i class="bi bi-arrow-left"></i> Powrót
                </button>
            }
            <h1 class="mb-0"><i class="bi bi-building text-purple"></i> @(office?.Name ?? "Ładowanie...")</h1>
            @if (office?.Location != null)
            {
                <small class="text-muted"><i class="bi bi-geo-alt"></i> @office.Location</small>
            }
        </div>
        @if (isAdmin)
        {
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary" @onclick="ToggleOfficeEditForm">
                    <i class="bi bi-pencil"></i> Edytuj biuro
                </button>
                <button class="btn btn-primary header-btn-purple" @onclick='() => Nav.NavigateTo($"/offices/{Id}/add-device")'>
                    <i class="bi bi-plus-lg"></i> Add device
                </button>
            </div>
        }
        else
        {
            <span class="badge bg-secondary p-2">Tryb tylko do odczytu</span>
        }
    </div>

    @if (isAdmin && showOfficeEdit && office is not null)
    {
        <OfficeEditForm @ref="officeEditForm"
                        Office="office"
                        OnSave="HandleOfficeSave"
                        OnCancel="HandleOfficeEditCancel" />
    }

    @if (isAdmin)
    {
        <DeviceForm IsVisible="showForm"
                    Device="editingDevice"
                    OfficeId="Id"
                    OnSuccess="OnDeviceFormSuccess"
                    OnCancel="OnDeviceFormCancel" />
    }

    <OfficeDashboardCharts Dashboard="dashboard" />

    <div class="row">
        <div class="col-lg-8">
            @if (devices is null)
            {
                <div class="text-center mt-5">
                    <div class="spinner-border text-purple" role="status"></div>
                    <p class="mt-2 text-muted">Ładowanie urządzeń...</p>
                </div>
            }
            else if (devices.Count == 0)
            {
                <div class="text-center mt-5 text-muted">
                    <i class="bi bi-hdd-network empty-icon"></i>
                    <p class="mt-2">Brak urządzeń w tym biurze.</p>
                </div>
            }
            else
            {
                <OfficeDevicesTable Devices="devices"
                                    ExpandedDeviceId="expandedDeviceId"
                                    OnToggle="ToggleDetails"
                                    ShowAdminActions="isAdmin"
                                    OnEditDevice="EditDevice"
                                    OnDeleteDevice="DeleteDevice"
                                    OnViewDeviceCharts="ViewDeviceCharts" />
            }
        </div>

        <div class="col-lg-4">
            <OfficeAlertsPanel Alerts="alerts" />
        </div>
    </div>
}
