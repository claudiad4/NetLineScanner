@page "/offices"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Biura</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-building text-purple"></i> Biura</h1>
    @if (isAdmin)
    {
        <button class="btn btn-primary header-btn-purple" @onclick="ToggleAddForm">
            <i class="bi bi-plus-lg"></i> Dodaj biuro
        </button>
    }
</div>

@if (isAdmin && showForm)
{
    <OfficeFormCard @ref="formCard"
                    EditingOffice="editingOffice"
                    IsLoading="isLoading"
                    OnSave="HandleSave"
                    OnCancel="CancelForm" />
}

@if (!isAdmin && user?.OfficeId is null)
{
    <div class="alert alert-warning mt-4">
        <i class="bi bi-exclamation-circle"></i> Nie zostałeś/aś jeszcze przypisany/a do żadnego biura. Skontaktuj się z administratorem.
    </div>
}
else if (offices is null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Ładowanie biur...</p>
    </div>
}
else if (offices.Count == 0)
{
    <div class="text-center mt-5 text-muted">
        <i class="bi bi-building empty-icon"></i>
        <p class="mt-2">Brak biur. @(isAdmin ? "Dodaj pierwsze biuro." : "Brak przypisanego biura.")</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var office in offices)
        {
            <OfficeCard Office="office"
                        ShowAdminActions="isAdmin"
                        OnOpen="OpenOffice"
                        OnEdit="StartEdit"
                        OnDelete="DeleteOffice" />
        }
    </div>
}
