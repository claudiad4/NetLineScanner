@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Użytkownicy</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people text-purple"></i> Użytkownicy</h1>
    <button class="btn btn-primary header-btn-purple" @onclick="ToggleAddForm">
        <i class="bi bi-plus-lg"></i> Dodaj użytkownika
    </button>
</div>

@if (showForm)
{
    <UserAddForm @ref="addForm"
                 Offices="offices"
                 IsLoading="isLoading"
                 OnCreate="HandleCreateUser"
                 OnCancel="CancelForm" />
}

@if (users == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Ładowanie...</p>
    </div>
}
else if (users.Count == 0)
{
    <div class="text-center mt-5 text-muted">
        <i class="bi bi-people empty-icon"></i>
        <p class="mt-2">Brak użytkowników.</p>
    </div>
}
else
{
    <UsersTable Users="users"
                Offices="offices"
                CurrentUserId="currentUserId"
                OnSave="HandleSaveUser"
                OnDelete="DeleteUser" />
}
