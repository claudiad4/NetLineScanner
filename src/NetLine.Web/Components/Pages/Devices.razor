@page "/devices"
@using NetLine.Web.Services
@using NetLine.Domain.Entities;
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject AlertNotificationService AlertService
@inject IConfiguration Config
@implements IAsyncDisposable

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Monitor Urządzeń</PageTitle>

<style>
    .text-purple {
        color: #6f42c1 !important;
    }

    .bg-soft-success {
        background-color: #d1e7dd !important;
        color: #0f5132 !important;
        border: 1px solid #badbcc !important;
    }

    .bg-soft-danger {
        background-color: #f8d7da !important;
        color: #842029 !important;
        border: 1px solid #f5c2c7 !important;
    }

    .detail-row {
        background-color: #f8faff;
        animation: fadeIn 0.3s ease-out;
    }

    .details-container {
        padding: 20px;
        border-left: 5px solid #6f42c1;
        margin: 10px 0 10px 40px;
        background: white;
        border-radius: 0 8px 8px 0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .table-hover tbody tr:not(.detail-row):hover {
        background-color: rgba(111, 66, 193, 0.05);
        cursor: pointer;
    }

    .badge-tech {
        font-size: 0.7rem;
        padding: 4px 8px;
        font-weight: bold;
        min-width: 55px;
        text-align: center;
        border-radius: 4px;
    }

    .main-container {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 20px;
        margin-top: 20px;
    }

    @@media (max-width: 1200px) {
        .main-container {
            grid-template-columns: 1fr;
        }

        .alerts-panel {
            order: -1;
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-speedometer2 text-purple"></i> Device monitoring</h1>
    <span class="badge bg-success border shadow-sm p-2">Status: Live</span>
</div>

@if (devices == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Initializing monitoring...</p>
    </div>
}
else
{
    <div class="main-container">
        <div>
            <div class="table-responsive shadow-sm rounded">
                <table class="table align-middle bg-white table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 40px;"></th>
                            <th style="width: 130px;">Status</th>
                            <th style="width: 140px;">Protocol</th>
                            <th>Device</th>
                            <th>IP address</th>
                            <th>Last scanned</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in devices)
                        {
                            <tr @onclick="() => ToggleDetails(device.Id)">
                                <td class="text-center">
                                    <i class="bi @(expandedDeviceId == device.Id ? "bi-chevron-down text-purple" : "bi-chevron-right text-muted")"></i>
                                </td>
                                <td>
                                    @{
                                        var statusClass = device.Status switch
                                        {
                                            "Online" => "bg-success",
                                            "Limited" => "bg-warning text-dark",
                                            "Offline" => "bg-danger",
                                            _ => "bg-secondary"
                                        };

                                        var iconClass = device.Status switch
                                        {
                                            "Online" => "bi-check-circle",
                                            "Limited" => "bi-exclamation-circle",
                                            "Offline" => "bi-x-circle",
                                            _ => "bi-question-circle"
                                        };
                                    }
                                    <span class="badge rounded-pill @statusClass w-100 shadow-sm">
                                        <i class="bi @iconClass"></i> @device.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <span class="badge @(device.PingResponseTimeMs.HasValue ? "bg-soft-success" : "bg-soft-danger") badge-tech">ICMP</span>
                                        <span class="badge @(!string.IsNullOrEmpty(device.SysUpTime) && device.SysUpTime != "No data" ? "bg-soft-success" : "bg-soft-danger") badge-tech">SNMP</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-3 d-flex align-items-center justify-content-center rounded-circle"
                                             style="width: 40px; height: 40px; background-color: #e9ecef; color: black;">
                                            <i class="bi @GetIconForType(device.DeviceType)" style="font-size: 1.2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@device.UserDefinedName</div>
                                            <small class="text-muted d-block" style="margin-top: -4px;">
                                                <i class="bi bi-tag"></i> @device.DeviceType
                                            </small>
                                        </div>
                                    </div>
                                </td>
                                <td><code class="text-purple fw-bold">@device.IpAddress</code></td>
                                <td><small class="text-muted">@device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</small></td>
                            </tr>

                            @if (expandedDeviceId == device.Id)
                            {
                                <tr class="detail-row">
                                    <td colspan="6">
                                        <div class="details-container">
                                            <div class="row">
                                                <div class="col-md-4 border-end">
                                                    <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-info-square"></i> System</h6>
                                                    <p class="mb-1 small"><strong>Name (SNMP):</strong> @(device.SysName ?? "No data")</p>
                                                    <p class="mb-1 small"><strong>Localisation of device:</strong> @(device.SysLocation ?? "No data")</p>
                                                    <p class="mb-1 small"><strong>Person responsible for device:</strong> @(device.SysContact ?? "No data")</p>
                                                </div>
                                                <div class="col-md-4 border-end">
                                                    <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-activity"></i> Status</h6>
                                                    <p class="mb-1 small"><strong>UpTime:</strong> @(device.SysUpTime ?? "No data")</p>
                                                    <p class="mb-1 small"><strong>Interfaces:</strong> @(device.SysInterfacesCount?.ToString() ?? "---")</p>
                                                    <p class="mb-1 small"><strong>Last PING:</strong> @(device.PingResponseTimeMs?.ToString() ?? "---") ms</p>
                                                </div>
                                                <div class="col-md-4">
                                                    <h6 class="fw-bold text-purple border-bottom pb-1"><i class="bi bi-file-earmark-text"></i> Other info</h6>
                                                    <small class="text-muted" style="font-size: 0.75rem;">
                                                        @if (string.IsNullOrEmpty(device.SysUpTime) || device.SysUpTime == "No data")
                                                        {
                                                            <span>@(device.PingResponseTimeMs.HasValue ? "Ping OK, SNMP not working." : "Device is unreachable.")</span>
                                                        }
                                                        else
                                                        {
                                                            @(device.SysDescr ?? "SNMP Data.")
                                                        }
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div>
            <AlertsHistoryPanel />
        </div>
    </div>
}

@code {
    private List<DeviceInfo>? devices;
    private HubConnection? hubConnection;
    private int? expandedDeviceId;
    private List<DeviceAlert> recentAlerts = new();

    private void ToggleDetails(int id) => expandedDeviceId = (expandedDeviceId == id) ? null : id;

    private string GetIconForType(string? type)
    {
        if (string.IsNullOrEmpty(type)) return "bi-three-dots";

        return type switch
        {
            "Computer" => "bi-pc-display",
            "Laptop" => "bi-laptop",
            "Server" => "bi-hdd-network",
            "Switch" => "bi-router",
            "Print" => "bi-printer",
            "Smartphone" => "bi-phone",
            "Tablet" => "bi-tablet",
            "Other" => "bi-three-dots",
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        var apiBaseUrl = Config["services:apiservice:http:0"] ?? Config["services:apiservice:https:0"];
        if (!string.IsNullOrEmpty(apiBaseUrl))
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiBaseUrl}/devicehub")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On("DeviceStatusUpdated", async () =>
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<DeviceAlert>("AlertCreated", (alert) =>
            {
                AlertService.AddNotification(alert);
                InvokeAsync(StateHasChanged);
            });

            await hubConnection.StartAsync();
        }
    }

    private async Task LoadData()
    {
        try 
        { 
            devices = await ApiClient.GetDevicesAsync();
            recentAlerts = await ApiClient.GetAlertsAsync(limit: 5);
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"ERROR: {ex.Message}"); 
        }
    }

    public async ValueTask DisposeAsync() 
    { 
        if (hubConnection is not null) 
            await hubConnection.DisposeAsync(); 
    }
}