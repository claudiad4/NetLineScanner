@page "/devices/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using NetLine.Web.Services
@using NetLine.Domain.Entities
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject AlertApiClient AlertClient
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>@(device?.UserDefinedName ?? "Urządzenie")</PageTitle>

<style>
    .text-purple {
        color: #6f42c1 !important;
    }

    .stat-card {
        border-left: 4px solid #6f42c1;
    }

    .device-tabs .nav-link {
        color: #6c757d;
        border: none;
        border-bottom: 3px solid transparent;
        border-radius: 0;
        padding: 0.75rem 1.25rem;
        font-weight: 500;
    }

    .device-tabs .nav-link:hover {
        color: #6f42c1;
        border-bottom-color: #d6c4ea;
    }

    .device-tabs .nav-link.active {
        color: #6f42c1;
        background: transparent;
        border-bottom-color: #6f42c1;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@if (accessDenied)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-shield-lock"></i> Nie masz uprawnień do tego urządzenia.
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4 gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Powrót
        </button>
        @if (device != null)
        {
            <h1 class="mb-0">
                <i class="bi @GetIconForType(device.DeviceType) text-purple"></i>
                @device.UserDefinedName
            </h1>
            <span class="badge @GetStatusClass(device.Status) rounded-pill px-3">
                @device.Status
            </span>
            @if (!isAdmin)
            {
                <span class="badge bg-secondary">Tryb tylko do odczytu</span>
            }
        }
    </div>

    @if (device == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-purple" role="status"></div>
            <p class="mt-2 text-muted">Ładowanie...</p>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Adres IP</small>
                        <div class="fw-bold text-purple fs-5"><code>@device.IpAddress</code></div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Ping</small>
                        <div class="fw-bold fs-5">@(device.PingResponseTimeMs?.ToString() ?? "---") ms</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Interfejsy</small>
                        <div class="fw-bold fs-5">@(device.SysInterfacesCount?.ToString() ?? "---")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Ostatni skan</small>
                        <div class="fw-bold fs-5">@device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white p-0">
                <ul class="nav nav-tabs device-tabs flex-wrap" role="tablist">
                    @foreach (var tab in availableTabs)
                    {
                        <li class="nav-item" role="presentation">
                            <button type="button"
                                    class="nav-link @(activeTab == tab.Key ? "active" : "")"
                                    @onclick="() => activeTab = tab.Key">
                                <i class="bi @tab.Icon me-1"></i> @tab.Label
                                @if (tab.Badge.HasValue && tab.Badge.Value > 0)
                                {
                                    <span class="badge bg-secondary ms-1">@tab.Badge</span>
                                }
                            </button>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-body">
                @if (activeTab == "system")
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted" style="width: 30%;">Typ</td>
                                <td>@RenderOrPlaceholder(device.DeviceType, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Nazwa SNMP</td>
                                <td>@RenderOrPlaceholder(device.SysName, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Lokalizacja</td>
                                <td>@RenderOrPlaceholder(device.SysLocation, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Kontakt</td>
                                <td>@RenderOrPlaceholder(device.SysContact, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">UpTime</td>
                                <td>@RenderOrPlaceholder(device.SysUpTime, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Opis</td>
                                <td>@RenderOrPlaceholder(device.SysDescr, true)</td>
                            </tr>
                        </tbody>
                    </table>
                    var systemMetrics = metrics.Where(m => m.Category == MonitoringCategory.System).OrderBy(m => m.MetricKey).ToList();
                    if (systemMetrics.Count > 0)
                    {
                        <h6 class="text-purple mt-4">Dodatkowe metryki systemowe</h6>
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th class="text-muted small" style="width: 30%;">Klucz</th>
                                    <th class="text-muted small" style="width: 25%;">Etykieta</th>
                                    <th class="text-muted small">Wartość</th>
                                    <th class="text-muted small">Czas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in systemMetrics)
                                {
                                    <tr>
                                        <td><code>@m.MetricKey</code></td>
                                        <td>@(m.Label ?? "")</td>
                                        <td>
                                            @if (m.NumericValue.HasValue)
                                            {
                                                @($"{m.NumericValue.Value:0.##} {m.Unit}")
                                            }
                                            else if (!string.IsNullOrWhiteSpace(m.TextValue))
                                            {
                                                @m.TextValue
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">@NoDataText</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@m.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
                else if (activeTab == "alerts")
                {
                    @if (alerts.Count == 0)
                    {
                        <p class="text-muted mb-0">Brak alertów dla tego urządzenia.</p>
                    }
                    else
                    {
                        <div style="max-height: 600px; overflow-y: auto;">
                            @foreach (var alert in alerts)
                            {
                                <div class="d-flex align-items-start mb-2 pb-2 border-bottom">
                                    <i class="bi @GetAlertIcon(alert.Type) me-2 mt-1 @GetAlertColor(alert.Type)"></i>
                                    <div class="flex-grow-1">
                                        <div class="small">@alert.Message</div>
                                        <small class="text-muted">@alert.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</small>
                                    </div>
                                    @if (!alert.IsRead)
                                    {
                                        <span class="badge bg-danger" style="height: 20px;">Nowy</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    var category = Enum.TryParse<MonitoringCategory>(activeTab, true, out var parsed) ? (MonitoringCategory?)parsed : null;
                    var categoryMetrics = category.HasValue
                        ? metrics.Where(m => m.Category == category.Value).OrderBy(m => m.MetricKey).ToList()
                        : new List<DeviceMetric>();
                    if (categoryMetrics.Count == 0)
                    {
                        <p class="text-muted mb-0"><i class="bi bi-info-circle me-1"></i> Urządzenie nie wysłało danych w tej kategorii.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th class="text-muted small" style="width: 30%;">Klucz</th>
                                    <th class="text-muted small" style="width: 25%;">Etykieta</th>
                                    <th class="text-muted small">Wartość</th>
                                    <th class="text-muted small">Czas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in categoryMetrics)
                                {
                                    <tr>
                                        <td><code>@m.MetricKey</code></td>
                                        <td>@(m.Label ?? "")</td>
                                        <td>
                                            @if (m.NumericValue.HasValue)
                                            {
                                                @($"{m.NumericValue.Value:0.##} {m.Unit}")
                                            }
                                            else if (!string.IsNullOrWhiteSpace(m.TextValue))
                                            {
                                                @m.TextValue
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">@NoDataText</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@m.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </div>
    }
}

