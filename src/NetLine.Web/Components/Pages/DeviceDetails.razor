@page "/devices/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using NetLine.Web.Services
@using NetLine.Domain.Entities
@rendermode InteractiveServer
@inject DeviceApiClient ApiClient
@inject AlertApiClient AlertClient
@inject CurrentUserService CurrentUser
@inject NavigationManager Nav

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>@(device?.UserDefinedName ?? "Urządzenie")</PageTitle>

<style>
    .text-purple {
        color: #6f42c1 !important;
    }

    .stat-card {
        border-left: 4px solid #6f42c1;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@if (accessDenied)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-shield-lock"></i> Nie masz uprawnień do tego urządzenia.
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4 gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Powrót
        </button>
        @if (device != null)
        {
            <h1 class="mb-0">
                <i class="bi @GetIconForType(device.DeviceType) text-purple"></i>
                @device.UserDefinedName
            </h1>
            <span class="badge @GetStatusClass(device.Status) rounded-pill px-3">
                @device.Status
            </span>
            @if (!isAdmin)
            {
                <span class="badge bg-secondary">Tryb tylko do odczytu</span>
            }
        }
    </div>

    @if (device == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-purple" role="status"></div>
            <p class="mt-2 text-muted">Ładowanie...</p>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Adres IP</small>
                        <div class="fw-bold text-purple fs-5"><code>@device.IpAddress</code></div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Ping</small>
                        <div class="fw-bold fs-5">@(device.PingResponseTimeMs?.ToString() ?? "---") ms</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Interfejsy</small>
                        <div class="fw-bold fs-5">@(device.SysInterfacesCount?.ToString() ?? "---")</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm stat-card h-100">
                    <div class="card-body">
                        <small class="text-muted">Ostatni skan</small>
                        <div class="fw-bold fs-5">@device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-bold text-purple bg-white">
                        <i class="bi bi-info-square"></i> Informacje systemowe
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tbody>
                                <tr><td class="text-muted">Typ</td><td>@device.DeviceType</td></tr>
                                <tr><td class="text-muted">Nazwa SNMP</td><td>@(device.SysName ?? "Brak danych")</td></tr>
                                <tr><td class="text-muted">Lokalizacja</td><td>@(device.SysLocation ?? "Brak danych")</td></tr>
                                <tr><td class="text-muted">Kontakt</td><td>@(device.SysContact ?? "Brak danych")</td></tr>
                                <tr><td class="text-muted">UpTime</td><td>@(device.SysUpTime ?? "Brak danych")</td></tr>
                                <tr><td class="text-muted">Opis</td><td><small>@(device.SysDescr ?? "Brak danych")</small></td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-header fw-bold text-purple bg-white d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-bell"></i> Historia alertów</span>
                        @if (alerts.Count > 0)
                        {
                            <span class="badge bg-secondary">@alerts.Count</span>
                        }
                    </div>
                    <div class="card-body" style="max-height: 500px; overflow-y: auto;">
                        @if (alerts.Count == 0)
                        {
                            <p class="text-muted text-center mt-3">Brak alertów dla tego urządzenia.</p>
                        }
                        else
                        {
                            @foreach (var alert in alerts)
                            {
                                <div class="d-flex align-items-start mb-2 pb-2 border-bottom">
                                    <i class="bi @GetAlertIcon(alert.Type) me-2 mt-1 @GetAlertColor(alert.Type)"></i>
                                    <div class="flex-grow-1">
                                        <div class="small">@alert.Message</div>
                                        <small class="text-muted">@alert.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</small>
                                    </div>
                                    @if (!alert.IsRead)
                                    {
                                        <span class="badge bg-danger" style="height: 20px;">Nowy</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private DeviceInfo? device;
    private List<DeviceAlert> alerts = [];
    private CurrentUserInfo? user;
    private bool isAdmin;
    private bool accessDenied;

    protected override async Task OnInitializedAsync()
    {
        user = await CurrentUser.GetAsync();
        isAdmin = user?.IsAdmin == true;

        try
        {
            device = await ApiClient.GetDeviceAsync(Id);

            if (device is null)
            {
                return;
            }

            if (!isAdmin && device.OfficeId != user?.OfficeId)
            {
                accessDenied = true;
                device = null;
                return;
            }

            alerts = await AlertClient.GetAlertsAsync(deviceId: Id, limit: 50);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR: {ex.Message}");
        }
    }

    private void GoBack()
    {
        if (device?.OfficeId != null)
            Nav.NavigateTo($"/offices/{device.OfficeId}");
        else if (isAdmin)
            Nav.NavigateTo("/offices");
        else
            Nav.NavigateTo("/devices");
    }

    private string GetIconForType(string? type) => type switch
    {
        "Computer" => "bi-pc-display",
        "Laptop" => "bi-laptop",
        "Server" => "bi-hdd-network",
        "Switch" => "bi-router",
        "Printer" => "bi-printer",
        "Smartphone" => "bi-phone",
        "Tablet" => "bi-tablet",
        _ => "bi-three-dots"
    };

    private string GetStatusClass(string? status) => status switch
    {
        "Online" => "bg-success",
        "Limited" => "bg-warning text-dark",
        "Offline" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetAlertIcon(AlertType type) => type switch
    {
        AlertType.WentOffline => "bi-x-circle-fill",
        AlertType.CameOnline => "bi-check-circle-fill",
        AlertType.HighLatency => "bi-exclamation-circle-fill",
        _ => "bi-info-circle-fill"
    };

    private string GetAlertColor(AlertType type) => type switch
    {
        AlertType.WentOffline => "text-danger",
        AlertType.CameOnline => "text-success",
        AlertType.HighLatency => "text-warning",
        _ => "text-info"
    };
}
