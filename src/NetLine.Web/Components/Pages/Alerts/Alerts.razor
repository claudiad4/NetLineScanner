@page "/alerts"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Alerty Urządzeń</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-bell text-purple"></i> Alerty</h1>
    @if (alerts is not null)
    {
        <span class="badge @(alerts.Any(a => !a.IsRead) ? "bg-danger badge-unread" : "bg-secondary") border shadow-sm p-2">
            @if (alerts.Any(a => !a.IsRead))
            {
                <i class="bi bi-exclamation-circle"></i> @alerts.Count(a => !a.IsRead) @:nieprzeczytane
            }
            else
            {
                <i class="bi bi-check-circle"></i> @:Wszystkie przeczytane
            }
        </span>
    }
</div>

@if (errorMessage is not null)
{
    <div class="error-banner">
        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Błąd:</strong> @errorMessage
        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="ClearError">
            <i class="bi bi-x"></i>
        </button>
    </div>
}

@if (alerts is null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Ładowanie alertów...</p>
    </div>
}
else
{
    <AlertsFilterBar Alerts="alerts"
                     SelectedFilter="selectedFilter"
                     IsLoading="isLoading"
                     OnFilterChanged="SetFilter"
                     OnMarkAllRead="MarkAllAsRead" />

    @if (filteredAlerts.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                @foreach (var alert in filteredAlerts.OrderByDescending(a => a.Timestamp))
                {
                    <AlertCard Alert="alert"
                               IsLoading="isLoading"
                               OnMarkRead="MarkAsRead" />
                }
            </div>
            <div class="col-lg-4">
                <AlertStatsPanel Alerts="alerts"
                                 IsLoading="isLoading"
                                 OnClearAll="ClearAllAlerts" />
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi @(selectedFilter == null ? "bi-inbox" : "bi-check-circle")"></i>
            </div>
            <h5 class="text-muted">@(selectedFilter == null ? "Brak alertów" : "Brak alertów w tym filtrze")</h5>
            @if (selectedFilter == null)
            {
                <p class="text-muted small">Wszystkie urządzenia działają prawidłowo</p>
            }
        </div>
    }
}
