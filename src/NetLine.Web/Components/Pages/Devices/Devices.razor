@page "/devices"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Monitor Urządzeń</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <i class="bi bi-speedometer2 text-purple"></i>
        Device monitoring
        @if (!isAdmin && user?.OfficeId is not null)
        {
            <small class="text-muted ms-2 fs-scope-hint">(tylko moje biuro)</small>
        }
    </h1>
    <span class="badge bg-success border shadow-sm p-2">Status: Live</span>
</div>

@if (!isAdmin && user?.OfficeId is null)
{
    <div class="alert alert-warning mt-4">
        <i class="bi bi-exclamation-circle"></i> Nie zostałeś/aś jeszcze przypisany/a do biura. Skontaktuj się z administratorem.
    </div>
}
else if (devices is null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-purple" role="status"></div>
        <p class="mt-2 text-muted">Initializing monitoring...</p>
    </div>
}
else
{
    <div class="main-container">
        <DeviceTable Devices="devices"
                     ExpandedDeviceId="expandedDeviceId"
                     OnToggle="ToggleDetails" />

        <AlertsHistoryPanel OfficeId="@scopedOfficeId" />
    </div>
}
