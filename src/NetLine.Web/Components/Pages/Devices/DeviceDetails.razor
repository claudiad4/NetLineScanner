@page "/devices/{Id:int}"
@namespace NetLine.Web.Components.Pages.Devices
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>@(device?.UserDefinedName ?? "Urządzenie")</PageTitle>

@if (accessDenied)
{
    <div class="alert alert-danger mt-4">
        <i class="bi bi-shield-lock"></i> Nie masz uprawnień do tego urządzenia.
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4 gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> Powrót
        </button>
        @if (device != null)
        {
            <h1 class="mb-0">
                <i class="bi @DeviceIcons.GetIconForType(device.DeviceType) text-purple"></i>
                @device.UserDefinedName
            </h1>
            <span class="badge @DeviceIcons.GetStatusClass(device.Status) rounded-pill px-3">
                @device.Status
            </span>
            @if (!isAdmin)
            {
                <span class="badge bg-secondary">Tryb tylko do odczytu</span>
            }
        }
    </div>

    @if (device == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-purple" role="status"></div>
            <p class="mt-2 text-muted">Ładowanie...</p>
        </div>
    }
    else
    {
        <DeviceQuickStats Device="device"
                          IsScanning="isScanning"
                          OnScanNowRequested="ScanNowAsync" />

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white p-0">
                <ul class="nav nav-tabs device-tabs flex-wrap" role="tablist">
                    @foreach (var tab in availableTabs)
                    {
                        <li class="nav-item" role="presentation">
                            <button type="button"
                                    class="nav-link @(activeTab == tab.Key ? "active" : "")"
                                    @onclick="() => activeTab = tab.Key">
                                <i class="bi @tab.Icon me-1"></i> @tab.Label
                                @if (tab.Badge.HasValue && tab.Badge.Value > 0)
                                {
                                    <span class="badge bg-secondary ms-1">@tab.Badge</span>
                                }
                            </button>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-body">
                @if (activeTab == "system")
                {
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted sys-key">Typ</td>
                                <td>@RenderOrPlaceholder(device.DeviceType, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Nazwa SNMP</td>
                                <td>@RenderOrPlaceholder(device.SysName, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Lokalizacja</td>
                                <td>@RenderOrPlaceholder(device.SysLocation, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Kontakt</td>
                                <td>@RenderOrPlaceholder(device.SysContact, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">UpTime</td>
                                <td>@RenderOrPlaceholder(device.SysUpTime, false)</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Opis</td>
                                <td>@RenderOrPlaceholder(device.SysDescr, true)</td>
                            </tr>
                        </tbody>
                    </table>
                    var systemMetrics = MetricsFor(MonitoringCategory.System);
                    if (systemMetrics.Count > 0)
                    {
                        <h6 class="text-purple mt-4">Dodatkowe metryki systemowe</h6>
                        <DeviceMetricsTable Metrics="systemMetrics" NoDataText="@NoDataText" />
                    }
                }
                else if (activeTab == "alerts")
                {
                    @if (alerts.Count == 0)
                    {
                        <p class="text-muted mb-0">Brak alertów dla tego urządzenia.</p>
                    }
                    else
                    {
                        <div class="alerts-scroll">
                            @foreach (var alert in alerts)
                            {
                                <div class="d-flex align-items-start mb-2 pb-2 border-bottom">
                                    <i class="bi @alert.Type.GetIcon() me-2 mt-1 @alert.Type.GetColorClass()"></i>
                                    <div class="flex-grow-1">
                                        <div class="small">@alert.Message</div>
                                        <small class="text-muted">@alert.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</small>
                                    </div>
                                    @if (!alert.IsRead)
                                    {
                                        <span class="badge bg-danger new-badge">Nowy</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    var category = Enum.TryParse<MonitoringCategory>(activeTab, true, out var parsed) ? (MonitoringCategory?)parsed : null;
                    var categoryMetrics = category.HasValue ? MetricsFor(category.Value) : new List<DeviceMetric>();

                    if (category == MonitoringCategory.Network && categoryMetrics.Count > 0)
                    {
                        <NetworkSubCategoryDropdown Metrics="categoryMetrics"
                                                    @bind-Selected="selectedNetworkSub" />
                        var filtered = categoryMetrics
                            .Where(m => NetworkSubCategoryFilter.Matches(m.MetricKey, selectedNetworkSub))
                            .ToList();
                        <DeviceMetricsTable Metrics="filtered"
                                            NoDataText="@NoDataText"
                                            EmptyMessage="Brak metryk w wybranej podkategorii." />
                    }
                    else
                    {
                        <DeviceMetricsTable Metrics="categoryMetrics" NoDataText="@NoDataText" />
                    }
                }
            </div>
        </div>
    }
}
