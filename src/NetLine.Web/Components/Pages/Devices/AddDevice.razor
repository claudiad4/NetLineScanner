@page "/offices/{OfficeId:int}/add-device"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

<PageTitle>Dodaj Urządzenie</PageTitle>

@if (showSuccessToast)
{
    <div class="custom-toast">
        <i class="bi bi-check-circle-fill toast-icon"></i>
        <div>
            <strong>Sukces!</strong><br />
            Urządzenie dodane pomyślnie.
        </div>
    </div>
}

<div class="d-flex justify-content-center align-items-center page-container">
    <div class="card p-4 shadow-sm form-card">
        <h3 class="mb-2 text-center">Dodaj nowe urządzenie</h3>
        <p class="text-center text-muted mb-4">
            <i class="bi bi-building"></i>
            Biuro: <strong>@(office?.Name ?? $"#{OfficeId}")</strong>
            @if (!string.IsNullOrWhiteSpace(office?.Location))
            {
                <span class="text-muted"> · @office.Location</span>
            }
        </p>

        <div class="mb-3">
            <label class="form-label d-block fw-bold">Adres IP</label>
            <div class="d-flex align-items-center justify-content-between">
                <input type="number" min="0" max="255" class="form-control text-center px-1 ip-octet" @bind="ip1" placeholder="192" />
                <span class="fw-bold">.</span>
                <input type="number" min="0" max="255" class="form-control text-center px-1 ip-octet" @bind="ip2" placeholder="168" />
                <span class="fw-bold">.</span>
                <input type="number" min="0" max="255" class="form-control text-center px-1 ip-octet" @bind="ip3" placeholder="0" />
                <span class="fw-bold">.</span>
                <input type="number" min="0" max="255" class="form-control text-center px-1 ip-octet" @bind="ip4" placeholder="1" />
            </div>
            @if (isIpInvalid)
            {
                <div class="text-danger small mt-1">
                    <i class="bi bi-exclamation-circle"></i> Wpisz poprawne liczby (0-255).
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Nazwa własna</label>
            <input @bind="label" class="form-control" placeholder="np. Drukarka w salonie" />
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Rodzaj urządzenia</label>
            <select class="form-select" @bind="deviceType">
                <option value="Computer">Komputer</option>
                <option value="Server">Serwer</option>
                <option value="Switch">Switch</option>
                <option value="Printer">Drukarka</option>
                <option value="Laptop">Laptop</option>
                <option value="Smartphone">Telefon</option>
                <option value="Tablet">Tablet</option>
                <option value="Other">Inne</option>
            </select>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary w-100 py-2 fw-bold submit-btn" @onclick="Submit" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                    <span> Zapisywanie...</span>
                }
                else
                {
                    <span>Dodaj urządzenie</span>
                }
            </button>
            <button class="btn btn-outline-secondary w-100 py-2" @onclick="Cancel" disabled="@isLoading">
                Anuluj
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>
