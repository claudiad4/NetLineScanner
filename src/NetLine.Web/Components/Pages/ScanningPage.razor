@page "/scanning"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using NetLine.Web.Services
@using NetLine.Domain.Entities

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<PageTitle>Skanowane parametry</PageTitle>

<style>
    .text-purple {
        color: #6f42c1 !important;
    }
</style>

<div class="d-flex align-items-center mb-4 gap-3">
    <h1 class="mb-0">
        <i class="bi bi-speedometer2 text-purple"></i>
        Skanowane parametry
    </h1>
    <span class="badge bg-secondary rounded-pill px-3">@ExpectedMetricsCatalog.All.Count pozycji</span>
</div>

<p class="text-muted">
    Wzór danych zbieranych przez skaner z każdego urządzenia. Jeżeli urządzenie nie zwróci wartości
    dla którejś pozycji, w widoku urządzenia pojawi się "unavailable, no data from device".
</p>

@foreach (var group in ExpectedMetricsCatalog.All.GroupBy(e => e.Category).OrderBy(g => g.Key.ToString()))
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-bold text-purple bg-white d-flex justify-content-between align-items-center">
            <span>@group.Key</span>
            <small class="text-muted">@group.Count() pozycji</small>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th style="width: 40%;">Klucz</th>
                        <th style="width: 45%;">Opis</th>
                        <th>Jednostka</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in group.OrderBy(x => x.Key))
                    {
                        <tr>
                            <td><code>@e.Key</code></td>
                            <td>@e.Label</td>
                            <td class="text-muted">@(e.Unit ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
