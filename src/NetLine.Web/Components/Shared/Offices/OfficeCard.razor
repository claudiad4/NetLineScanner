@using NetLine.Domain.Entities

<div class="col-md-4 mb-4">
    <div class="card shadow-sm h-100 office-card" @onclick="() => OnOpen.InvokeAsync(Office.Id)">
        <div class="card-body">
            <div class="d-flex align-items-center mb-3">
                <div class="office-icon me-3">
                    <i class="bi bi-building text-purple"></i>
                </div>
                <div>
                    <h5 class="mb-0 fw-bold">@Office.Name</h5>
                    <small class="text-muted">@(Office.Location ?? "Brak lokalizacji")</small>
                </div>
            </div>
        </div>
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <small class="text-muted">Dodano: @Office.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</small>
            @if (ShowAdminActions)
            {
                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OnEdit.InvokeAsync(Office)">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(Office.Id)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Office Office { get; set; } = default!;
    [Parameter] public bool ShowAdminActions { get; set; }
    [Parameter] public EventCallback<int> OnOpen { get; set; }
    [Parameter] public EventCallback<Office> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
}
