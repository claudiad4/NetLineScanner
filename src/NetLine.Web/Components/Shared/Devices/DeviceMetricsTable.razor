@using NetLine.Domain.Entities

@if (Metrics.Count == 0)
{
    <p class="text-muted mb-0"><i class="bi bi-info-circle me-1"></i> @EmptyMessage</p>
}
else
{
    <table class="table table-sm mb-0">
        <thead>
            <tr>
                <th class="text-muted small key-col">Klucz</th>
                <th class="text-muted small label-col">Etykieta</th>
                <th class="text-muted small">Wartość</th>
                <th class="text-muted small info-col text-center">Info</th>
                <th class="text-muted small">Czas</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Metrics)
            {
                <tr>
                    <td>
                        <code>@m.MetricKey</code>
                    </td>
                    <td>@(m.Label ?? "")</td>
                    <td>
                        @if (m.NumericValue.HasValue)
                        {
                            @($"{m.NumericValue.Value:0.##} {m.Unit}")
                        }
                        else if (!string.IsNullOrWhiteSpace(m.TextValue))
                        {
                            @m.TextValue
                        }
                        else
                        {
                            <span class="text-muted fst-italic">@NoDataText</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="@HelpAnchor(m.MetricKey)"
                           target="_blank"
                           rel="noopener"
                           class="text-muted text-decoration-none"
                           title="Co to znaczy?"
                           aria-label="Pomoc dla metryki @m.MetricKey">
                            <i class="bi bi-info-circle" aria-hidden="true"></i>
                        </a>
                    </td>
                    <td class="text-muted small">@m.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter, EditorRequired] public IReadOnlyList<DeviceMetric> Metrics { get; set; } = [];
    [Parameter] public string NoDataText { get; set; } = "Brak danych od urządzenia";
    [Parameter] public string EmptyMessage { get; set; } = "Urządzenie nie wysłało danych w tej kategorii.";

    private static string HelpAnchor(string key)
    {
        var parts = key.Split('.')
            .Where(p => !int.TryParse(p, out _))
            .Select(p => p.Replace('_', '-'));
        return "/help#" + string.Join("-", parts);
    }
}
