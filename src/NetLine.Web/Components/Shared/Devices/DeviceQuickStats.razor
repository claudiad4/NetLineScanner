@using NetLine.Domain.Entities

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Adres IP</small>
                <div class="fw-bold text-purple fs-5"><code>@Device.IpAddress</code></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Ping</small>
                <div class="fw-bold fs-5">@(Device.PingResponseTimeMs?.ToString() ?? "---") ms</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Interfejsy</small>
                <div class="fw-bold fs-5">@(Device.SysInterfacesCount?.ToString() ?? "---")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Ostatni skan</small>
                <div class="fw-bold fs-5">@Device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</div>
                <small class="text-muted">@NextScanLabel(Device)</small>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DeviceInfo Device { get; set; } = default!;

    private static string NextScanLabel(DeviceInfo device)
    {
        if (device.NextScanAt is not { } next)
        {
            return "Następny skan: zaraz";
        }

        var delta = next - DateTime.UtcNow;
        if (delta <= TimeSpan.Zero)
        {
            return "Następny skan: zaraz";
        }

        if (delta.TotalMinutes < 1) return $"Następny skan za ~{(int)delta.TotalSeconds} s";
        if (delta.TotalHours < 1) return $"Następny skan za ~{(int)delta.TotalMinutes} min";
        return $"Następny skan za ~{delta.TotalHours:F1} h";
    }
}
