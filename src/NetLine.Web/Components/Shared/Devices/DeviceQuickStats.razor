@using NetLine.Domain.Entities

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Adres IP</small>
                <div class="fw-bold text-purple fs-5"><code>@Device.IpAddress</code></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Ping</small>
                <div class="fw-bold fs-5">@(Device.PingResponseTimeMs?.ToString() ?? "---") ms</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Interfejsy</small>
                <div class="fw-bold fs-5">@(Device.SysInterfacesCount?.ToString() ?? "---")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Ostatni skan</small>
                <div class="fw-bold fs-5">@Device.LastScanned.ToLocalTime().ToString("HH:mm:ss")
                @{
                    var upcoming = GetUpcomingScans(Device).ToList();
                }
                @for (var i = 0; i < upcoming.Count; i++)
                {
                    var scan = upcoming[i];
                    var prefix = i == 0 ? "Następny skan za" : "Następnie za";
                    <small class="text-muted d-block">@prefix @FormatDelta(scan.Delta): @scan.Components</small>
                }

                </div>
                <button type="button"
                        class="btn btn-sm btn-outline-primary mt-2"
                        disabled="@IsScanning"
                        @onclick="HandleScanNowClick">
                    @if (IsScanning)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Skanowanie...</span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-repeat me-1"></i>
                        <span>Skanuj teraz</span>
                    }
                </button>
            </div>
        </div>
    </div>


    </div>
@code {
    [Parameter, EditorRequired] public DeviceInfo Device { get; set; } = default!;
    [Parameter] public bool IsScanning { get; set; }
    [Parameter] public EventCallback OnScanNowRequested { get; set; }

    private Task HandleScanNowClick() => OnScanNowRequested.InvokeAsync();

    private static readonly (ScanFrequency Tier, string Components)[] TierComponents =
    {
        (ScanFrequency.Light, "Ping"),
        (ScanFrequency.Medium, "DNS, CPU, RAM, interfejsy, system, syslog"),
        (ScanFrequency.Heavy, "skan portów"),
    };
    private static IEnumerable<(TimeSpan Delta, string Components)> GetUpcomingScans(DeviceInfo device)
    {
        var now = DateTime.UtcNow;
        return TierComponents
            .Select(t => (NextAt: NextAtFor(device, t.Tier, now), t.Components))
            .OrderBy(t => t.NextAt)
            .Select(t => (Delta: t.NextAt - now, t.Components));
    }
    private static DateTime NextAtFor(DeviceInfo device, ScanFrequency tier, DateTime now)
    {
        var (last, interval) = tier switch
        {
            ScanFrequency.Light => (device.LastLightScanAt, ScanIntervals.Light),
            ScanFrequency.Medium => (device.LastMediumScanAt, ScanIntervals.Medium),
            ScanFrequency.Heavy => (device.LastHeavyScanAt, ScanIntervals.Heavy),
            _ => (null, TimeSpan.Zero)
        };
        return last is null ? now : last.Value + interval;
    }
    private static string FormatDelta(TimeSpan delta)
    {
        if (delta <= TimeSpan.Zero) return "~teraz";
        if (delta.TotalMinutes < 1) return $"~{(int)delta.TotalSeconds} s";
        if (delta.TotalHours < 1) return $"~{(int)delta.TotalMinutes} min";
        return $"~{delta.TotalHours:F1} h";
    }
}</div
