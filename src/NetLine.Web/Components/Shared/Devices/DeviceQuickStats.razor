@using NetLine.Domain.Entities

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Adres IP</small>
                <div class="fw-bold text-purple fs-5"><code>@Device.IpAddress</code></div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">
                    Ping
                    <a href="/help#ping-rtt-avg-ms"
                       target="_blank"
                       rel="noopener"
                       class="ms-1 text-muted text-decoration-none"
                       title="Co to znaczy?"
                       aria-label="Pomoc: średni czas odpowiedzi ping">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>
                    </a>
                </small>
                <div class="fw-bold fs-5">@(Device.PingResponseTimeMs?.ToString() ?? "---") ms</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">
                    Interfejsy
                    <a href="/help#net-if-total"
                       target="_blank"
                       rel="noopener"
                       class="ms-1 text-muted text-decoration-none"
                       title="Co to znaczy?"
                       aria-label="Pomoc: liczba interfejsów sieciowych">
                        <i class="bi bi-info-circle" aria-hidden="true"></i>
                    </a>
                </small>
                <div class="fw-bold fs-5">@(Device.SysInterfacesCount?.ToString() ?? "---")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body">
                <small class="text-muted">Ostatni skan</small>
                <div class="fw-bold fs-5">@Device.LastScanned.ToLocalTime().ToString("HH:mm:ss")</div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DeviceInfo Device { get; set; } = default!;
}
