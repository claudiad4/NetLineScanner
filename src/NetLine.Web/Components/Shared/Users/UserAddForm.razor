@using NetLine.Domain.Entities

<div class="card p-4 mb-4 shadow-sm user-add-form">
    <h5 class="mb-3">Nowy użytkownik</h5>
    <div class="mb-3">
        <label class="form-label fw-bold">E-mail</label>
        <input type="email" @bind="email" class="form-control" placeholder="user@example.com" />
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Imię</label>
            <input @bind="firstName" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Nazwisko</label>
            <input @bind="lastName" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Hasło</label>
        <input type="password" @bind="password" class="form-control" placeholder="min. 8 znaków, wielka litera, znak specjalny" />
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Rola</label>
        <select class="form-select" @bind="role">
            <option value="User">User</option>
            <option value="Admin">Admin</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label fw-bold">Biuro</label>
        <select class="form-select" @bind="officeId">
            <option value="">— Brak —</option>
            @if (Offices is not null)
            {
                @foreach (var o in Offices)
                {
                    <option value="@o.Id">@o.Name</option>
                }
            }
        </select>
    </div>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    <div class="d-flex gap-2">
        <button class="btn btn-primary w-100 user-add-form__save" @onclick="HandleCreate" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
                <span> Tworzenie...</span>
            }
            else
            {
                <span>Utwórz</span>
            }
        </button>
        <button class="btn btn-outline-secondary w-100" @onclick="OnCancel">Anuluj</button>
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<Office>? Offices { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<UserAddRequest> OnCreate { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    public record UserAddRequest(string Email, string Password, int? OfficeId, string Role, string FirstName, string LastName);

    private string email = "";
    private string password = "";
    private string firstName = "";
    private string lastName = "";
    private string role = "User";
    private string officeId = "";
    private string? errorMessage;

    public void SetError(string? message)
    {
        errorMessage = message;
        StateHasChanged();
    }

    public void Reset()
    {
        email = "";
        password = "";
        firstName = "";
        lastName = "";
        role = "User";
        officeId = "";
        errorMessage = null;
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "E-mail i hasło są wymagane.";
            return;
        }

        errorMessage = null;
        int? parsedOffice = int.TryParse(officeId, out var o) ? o : null;
        await OnCreate.InvokeAsync(new UserAddRequest(email, password, parsedOffice, role, firstName, lastName));
    }
}
